      "action_actors": {
        "create": [
          "product manager"
        ],
        "review": [
          "pricing owner"
        ],
        "approve": [
          "approver"
        ],
        "activate": [
          "pricing owner"
        ],
        "close": [
          "pricing owner"
        ],
        "cancel": [
          "pricing owner"
        ],
        "archive": [
          "pricing owner"
        ]
