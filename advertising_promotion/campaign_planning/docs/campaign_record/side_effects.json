{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "media_plan",
      "values": {
        "title": {
          "$template": "Media Plan for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "MEDIA_PLAN-{reference_no|id}"
        },
        "source_reference": {
          "$from": [
            "reference_no",
            "id"
          ]
        },
        "source_doc_id": {
          "$template": "{id}"
        },
        "approval_status": "approved"
      }
    }
  ],
  "launch": [
    {
      "type": "create_record",
      "effect_id": "campaign_result",
      "target_doc": "campaign_result",
      "lookup": {
        "reference_no": {
          "$template": "CMPR-{campaign_code|reference_no|pk}"
        }
      },
      "values": {
        "title": {
          "$template": "Campaign Result {campaign_code|reference_no|pk}"
        },
        "reference_no": {
          "$template": "CMPR-{campaign_code|reference_no|pk}"
        },
        "result_code": {
          "$template": "CMPR-{campaign_code|reference_no|pk}"
        },
        "linked_campaign": {
          "$from": [
            "campaign_code",
            "reference_no",
            "pk"
          ]
        },
        "reporting_period": {
          "$from": [
            "start_date"
          ]
        },
        "spend_total": "0.00",
        "workflow_state": "active"
      }
    }
  ],
  "pause": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "paused"
      }
    }
  ],
  "close": [
    {
      "type": "upsert_record",
      "effect_id": "campaign_result_rollup",
      "target_doc": "campaign_result",
      "lookup": {
        "linked_campaign": {
          "$from": [
            "campaign_code",
            "reference_no",
            "pk"
          ]
        }
      },
      "values": {
        "title": {
          "$template": "Campaign Result {campaign_code|reference_no|pk}"
        },
        "reference_no": {
          "$template": "CMPR-{campaign_code|reference_no|pk}"
        },
        "result_code": {
          "$template": "CMPR-{campaign_code|reference_no|pk}"
        },
        "linked_campaign": {
          "$from": [
            "campaign_code",
            "reference_no",
            "pk"
          ]
        },
        "reporting_period": {
          "$from": [
            "end_date",
            "start_date"
          ]
        },
        "spend_total": "0.00",
        "workflow_state": "completed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
